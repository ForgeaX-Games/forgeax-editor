# Build / runtime artifacts
node_modules/
*.log
dist/
build/

# python bytecode caches (harness venv + forgeax scripts emit these on every
# invocation; never tracked).
__pycache__/
*.pyc

# .forgeax-harness is a floating clone of forgeax-editor-harness (NOT a submodule —
# see docs/specs/2026-06-17-harness-floating-clone.md). The editor never tracks it;
# `bun run harness:sync` clones/pulls it on install.
/.forgeax-harness/

# Vite caches (one per package)
.vite/

# run.sh symlinks the studio's instance-local .forgeax into editor-play-runtime
# so engine vite can resolve /preview/.forgeax/games/<id>/...
# It must never be tracked.
.forgeax
.forgeax/

# Playwright scratch (snapshots, console dumps, traces)
.playwright-cli/
.playwright-mcp/
test-results/
playwright-report/

# TypeScript / IDE
*.tsbuildinfo
.vscode/
.idea/
*.swp
.DS_Store

# Secrets — defense-in-depth, even though dev work happens in the studio root
.env
.env.*
!.env.example
.forgeax-debug/
.worktrees/

# local scratch games for manual editor testing (not tracked)
.forgeax-scratch/

# forgeax-editor-solo per-run experiment reports live in the harness clone
# (.forgeax-harness/solo/experiments/), already covered by /.forgeax-harness/ above —
# they are committed in forgeax-editor-harness.git, never in this repo.
# See skills/forgeax-editor-solo/SKILL.md.

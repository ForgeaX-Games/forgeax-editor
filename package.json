{
  "name": "@forgeax/editor",
  "version": "0.1.0",
  "private": false,
  "license": "Apache-2.0",
  "type": "module",
  "description": "forgeax editor monorepo — 5 packages (core / shared / panels / edit-runtime / play-runtime) for the forgeax editor",
  "exports": {
    ".": "./src/index.ts",
    "./panels": "./packages/editor-panels/src/manifest.ts",
    "./protocol": "./src/core/protocol.ts",
    "./package.json": "./package.json"
  },
  "workspaces": [
    "packages/*",
    "packages/engine/packages/*"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "echo 'build: nothing to bundle (packages publish source directly)'",
    "dev": "echo 'use per-package dev scripts: bun -F @forgeax/editor-edit-runtime dev'",
    "lint": "node scripts/lint-sync-channel-panels.mjs",
    "lint:sync-channel": "node scripts/lint-sync-channel-panels.mjs",
    "lint:dep": "dependency-cruise --output-type err-html -c .dependency-cruiser.cjs packages"
  },
  "dependencies": {
    "@forgeax/interface": "workspace:*",
    "@forgeax/editor-shared": "workspace:*",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "dependency-cruiser": "^17.4.3",
    "typescript": "^5.6.3"
  }
}

{
  "name": "@forgeax/editor",
  "version": "0.1.0",
  "private": false,
  "license": "Apache-2.0",
  "type": "module",
  "description": "forgeax editor monorepo — 5 packages (core / content-browser / panels / edit-runtime / play-runtime) + 5 entry points (. / ./edit / ./play / ./panels / ./protocol) for the forgeax editor",
  "repository": {
    "type": "git",
    "url": "https://github.com/ForgeaX-Games/forgeax-studio.git",
    "directory": "packages/editor"
  },
  "homepage": "https://github.com/ForgeaX-Games/forgeax-studio/tree/main/packages/editor",
  "bugs": {
    "url": "https://github.com/ForgeaX-Games/forgeax-studio/issues"
  },
  "exports": {
    ".": "./src/index.ts",
    "./app-kit": "./src/app-kit.ts",
    "./edit": "./src/edit.ts",
    "./panels": "./packages/panels/src/manifest.ts",
    "./play": "./src/play.ts",
    "./protocol": "./src/protocol.ts",
    "./package.json": "./package.json"
  },
  "workspaces": [
    "packages/*",
    "packages/engine/packages/*"
  ],
  "scripts": {
    "harness:sync": "node scripts/sync-harness.mjs",
    "postinstall": "node scripts/sync-harness.mjs",
    "typecheck": "bun run typecheck:root; r1=$?; bun run --filter '@forgeax/editor-*' typecheck; r2=$?; exit $((r1||r2))",
    "typecheck:root": "tsc --noEmit",
    "build": "echo 'build: nothing to bundle (packages publish source directly)'",
    "dev": "vite",
    "dev:edit-runtime": "FORGEAX_INTERFACE_PORT=15290 bun -F @forgeax/editor-edit-runtime dev -- --port 15280 --strictPort",
    "dev:standalone": "node scripts/dev-standalone.mjs",
    "cli": "node scripts/cli.mjs",
    "setup": "node scripts/cli.mjs install",
    "start": "node scripts/cli.mjs run",
    "stop": "node scripts/cli.mjs stop",
    "bootstrap-worktree": "node scripts/bootstrap-worktree.mjs",
    "lint": "node scripts/lint-sync-channel-panels.mjs && node scripts/lint-no-direct-api-fetch.mjs && node scripts/lint-no-bare-engine-shim.mjs && node scripts/lint-no-second-world.mjs && node scripts/lint-no-any-in-store.mjs && node scripts/lint-play-vag-boundary.mjs && node scripts/lint-readme-bilingual.mjs && node scripts/lint-op-via-gateway.mjs && node scripts/lint-unique-mutator.mjs && node scripts/lint-no-store-setter-sugar.mjs",
    "lint:sync-channel": "node scripts/lint-sync-channel-panels.mjs",
    "lint:api-seam": "node scripts/lint-no-direct-api-fetch.mjs",
    "lint:engine-shim": "node scripts/lint-no-bare-engine-shim.mjs",
    "lint:dep": "dependency-cruiser --output-type err-html -c .dependency-cruiser.cjs packages",
    "selfcheck:b2": "bun scripts/selfcheck-standalone-b2.mjs",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps chromium",
    "selfcheck": "node scripts/selfcheck.mjs"
  },
  "dependencies": {
    "@forgeax/editor-core": "workspace:*",
    "@forgeax/editor-edit-runtime": "workspace:*",
    "@forgeax/editor-play-runtime": "workspace:*",
    "@forgeax/interface": "workspace:*",
    "@forgeax/platform-io": "workspace:*",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@forgeax/engine-gltf": "workspace:*",
    "@forgeax/engine-image": "workspace:*",
    "@forgeax/engine-vite-plugin-pack": "workspace:*",
    "@forgeax/engine-vite-plugin-shader": "workspace:*",
    "@playwright/test": "^1.45.0",
    "@vitejs/plugin-react": "^4.3.0",
    "dependency-cruiser": "^17.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.6.3",
    "vite": "*"
  }
}

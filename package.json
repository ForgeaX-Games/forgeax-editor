{
  "name": "@forgeax/editor",
  "version": "0.1.0",
  "private": false,
  "license": "Apache-2.0",
  "type": "module",
  "description": "forgeax editor monorepo — 5 packages (core / shared / panels / edit-runtime / play-runtime) + 5 entry points (. / ./edit / ./play / ./panels / ./protocol) for the forgeax editor",
  "repository": {
    "type": "git",
    "url": "https://github.com/ForgeaXGame/forgeax-studio.git",
    "directory": "packages/editor"
  },
  "homepage": "https://github.com/ForgeaXGame/forgeax-studio/tree/main/packages/editor",
  "bugs": {
    "url": "https://github.com/ForgeaXGame/forgeax-studio/issues"
  },
  "exports": {
    ".": "./src/index.ts",
    "./app-kit": "./src/app-kit.ts",
    "./edit": "./src/edit.ts",
    "./panels": "./packages/editor-panels/src/manifest.ts",
    "./play": "./src/play.ts",
    "./protocol": "./src/protocol.ts",
    "./package.json": "./package.json"
  },
  "workspaces": [
    "packages/*",
    "packages/engine/packages/*"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "echo 'build: nothing to bundle (packages publish source directly)'",
    "dev": "vite",
    "lint": "node scripts/lint-sync-channel-panels.mjs",
    "lint:sync-channel": "node scripts/lint-sync-channel-panels.mjs",
    "lint:dep": "dependency-cruise --output-type err-html -c .dependency-cruiser.cjs packages",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps chromium"
  },
  "dependencies": {
    "@forgeax/editor-core": "workspace:*",
    "@forgeax/editor-edit-runtime": "workspace:*",
    "@forgeax/editor-play-runtime": "workspace:*",
    "@forgeax/editor-shared": "workspace:*",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@forgeax/interface": "workspace:*",
    "@playwright/test": "^1.45.0",
    "@vitejs/plugin-react": "^4.3.0",
    "dependency-cruiser": "^17.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.6.3",
    "vite": "*"
  }
}

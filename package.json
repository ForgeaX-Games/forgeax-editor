{
  "name": "@forgeax-studio/editor-runtime",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "forgeax editor runtime: renders an editable scene with the forgeax engine (WebGPU) inside the interface Edit mode. Sibling of @forgeax-studio/preview-runtime; served at base /editor/ and embedded by interface via iframe.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@forgeax/engine-app": "workspace:*",
    "@forgeax/engine-runtime": "workspace:*",
    "@forgeax/engine-ecs": "workspace:*",
    "@forgeax/engine-types": "workspace:*",
    "@forgeax/engine-vite-plugin-shader": "workspace:*",
    "@forgeax/engine-vite-plugin-pack": "workspace:*",
    "@forgeax/engine-input": "workspace:*",
    "@forgeax/engine-rhi": "workspace:*",
    "@forgeax/engine-rhi-webgpu": "workspace:*",
    "@forgeax/engine-rhi-wgpu": "workspace:*",
    "@forgeax/engine-image": "workspace:*",
    "@forgeax/engine-pack": "workspace:*",
    "@forgeax/engine-shader": "workspace:*",
    "@forgeax/engine-math": "workspace:*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@forgeax/engine-gltf": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^6.0.5"
  }
}

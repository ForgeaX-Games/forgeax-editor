# Imported binaries + their cooked meta are runtime-only test artifacts, never
# tracked (zero-binary invariant; the 62MB city GLB stays out of git).
assets/*.glb
assets/*.gltf
assets/*.fbx
assets/*.bin
assets/*.glb.meta.json
assets/*.gltf.meta.json
assets/*.fbx.meta.json


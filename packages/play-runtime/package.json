  "description": "forgeax editor Play mode thick host — FPS mouse capture, physics gate, per-game pack-index, loading overlay, diagnostic overlay, VAG_CONSOLE bridge",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },

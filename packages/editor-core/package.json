{
  "name": "@forgeax/editor-core",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "license": "Apache-2.0",
  "sideEffects": false,
  "description": "core types + shared runtime — EditSession, EditorBus, ComponentSchema, VAG protocol, manifest, store, entity ops, context menu, dock bridge",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./protocol": {
      "types": "./src/protocol.ts",
      "import": "./src/protocol.ts"
    },
    "./manifest": {
      "types": "./src/manifest.ts",
      "import": "./src/manifest.ts"
    },
    "./package.json": "./package.json"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^3.25.0",
    "react": "^19.0.0",
    "@forgeax/engine-app": "workspace:*",

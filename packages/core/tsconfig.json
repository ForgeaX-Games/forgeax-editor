{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "jsx": "react-jsx",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "types": ["bun"],
    "noEmit": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true
  },
  "include": ["src", "../../types/forgeax-engine-shims.d.ts"],
  // broken-syntax.ts is an INTENTIONALLY malformed fixture loaded as raw text by
  // the discoverer test (discoverer.test.ts) to prove error handling — it must
  // never be typechecked (it would trip TS1005). Everything else under
  // __tests__/ is typechecked normally.
  "exclude": ["src/__tests__/fixtures/discoverer/broken-syntax.ts"]
}
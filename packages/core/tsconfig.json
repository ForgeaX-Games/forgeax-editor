{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "jsx": "react-jsx",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "types": ["bun"],
    "noEmit": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true
  },
  "include": ["src", "../../types/forgeax-engine-shims.d.ts"],
  // broken-syntax.ts is an INTENTIONALLY malformed fixture loaded as raw text by
  // the discoverer test (discoverer.test.ts) to prove error handling — it must
  // never be typechecked (it would trip TS1005). Everything else under
  // __tests__/ is typechecked normally.
  //
  // ctx-world-negative.ts is an INTENTIONALLY type-erroneous fixture (AC-01
  // tsc-negative guard, F-3): it reaches `ctx.world` to prove DocApplierCtx has
  // no world field. It must NOT trip the normal gate — ctx-world-negative.test.ts
  // compiles it on demand via tsconfig.ctx-negative.json and asserts the error.
  "exclude": [
    "src/__tests__/fixtures/discoverer/broken-syntax.ts",
    "src/__tests__/fixtures/ctx-world-negative.ts"
  ]
}
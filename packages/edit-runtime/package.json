{
  "name": "@forgeax/editor-edit-runtime",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "license": "Apache-2.0",
  "description": "forgeax editor Edit mode runtime — engine boot + camera + skylight + seed + sync + dock shell + zustand store + EditorApp shell + context menu service",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },

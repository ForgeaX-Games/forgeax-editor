{
  "name": "@forgeax/editor-panels",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "license": "Apache-2.0",
  "sideEffects": false,
  "description": "forgeax editor business panels (Hierarchy, Inspector, Assets, History, Capabilities, Material, Mesh, Launcher, AssetInspector, Systems) + panel manifest SSOT. The Assets panel lazy-loads @forgeax/editor-content-browser.",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./panels": {
      "types": "./src/manifest.ts",
      "import": "./src/manifest.ts"
    },
    "./package.json": "./package.json"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@forgeax/editor-core": "workspace:*",
    "@forgeax/editor-content-browser": "workspace:*",
    "@forgeax/editor-ui": "workspace:*",
    "@forgeax/engine-ecs": "workspace:*",
    "@forgeax/engine-runtime": "workspace:*",
    "lucide-react": "^0.460.0",
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.10.2",
    "@types/bun": "^1.3.13",
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.6.3"
  }
}
